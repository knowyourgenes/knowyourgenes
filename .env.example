# ---------------------------------------------------------------------------
# Database (Postgres)
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/kyg?schema=public"

# ---------------------------------------------------------------------------
# NextAuth v5
# ---------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# In production, set this to your canonical URL. In dev, NextAuth reads from request.
# AUTH_URL="https://kyg.in"

# ---------------------------------------------------------------------------
# Google OAuth
# Get from https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs must include: http://localhost:3000/api/auth/callback/google
#                                        https://kyg.in/api/auth/callback/google
# ---------------------------------------------------------------------------
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ---------------------------------------------------------------------------
# Sanity CMS (blog content)
# Create a project at https://www.sanity.io/manage, copy project ID + dataset.
# Studio is embedded at /studio - sign in with your Sanity account.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2024-10-01"
# Optional: read token for fetching drafts from server components
SANITY_API_READ_TOKEN=""

# ---------------------------------------------------------------------------
# Razorpay (payments)
# ---------------------------------------------------------------------------
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# ---------------------------------------------------------------------------
# Cloudflare R2 (private report PDFs - S3-compatible)
# Create the bucket and an API token at: https://dash.cloudflare.com → R2.
# R2_ACCOUNT_ID is the Cloudflare account id (NOT the bucket id).
# Reports are never made public - downloads use short-lived presigned URLs.
# ---------------------------------------------------------------------------
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="kyg-reports"

# ---------------------------------------------------------------------------
# Email (SendGrid or AWS SES)
# ---------------------------------------------------------------------------
SENDGRID_API_KEY=""
EMAIL_FROM="KYG <care@kyg.in>"

# ---------------------------------------------------------------------------
# WhatsApp Business API (Gupshup / Wati)
# ---------------------------------------------------------------------------
WHATSAPP_API_URL=""
WHATSAPP_API_KEY=""
WHATSAPP_SOURCE_NUMBER=""

# ---------------------------------------------------------------------------
# MapMyIndia / Mappls (reverse geocode for /api/location/resolve)
# Sign up: https://apisetu.mappls.com → Cloud → create app → Credentials tab.
# The Static Key is a single long-lived REST API token. Server-only - never
# expose to the client. Whitelist your prod server IP in the Mappls console.
# ---------------------------------------------------------------------------
MAPPLS_API_KEY=""

# ---------------------------------------------------------------------------
# Delhivery (B2C surface API - kit forward + sample reverse pickup)
#
# Auth: API token from your Delhivery dashboard (Settings → API).
# Per-lab pickup-location names live in the Lab table (/admin/labs); the env
# var below is just the global fallback used when no lab is resolved.
#
# Sandbox base URL:    https://staging-express.delhivery.com
# Production base URL: https://track.delhivery.com
#
# Set DELHIVERY_MOCK=true to short-circuit all calls with deterministic fake
# responses - useful before credentials land. Auto-enabled when TOKEN is empty.
#
# DELHIVERY_WEBHOOK_SECRET is the shared secret you give Delhivery support
# when registering /api/webhooks/delhivery; it's checked against the
# X-Delhivery-Token header on every push.
# ---------------------------------------------------------------------------
DELHIVERY_BASE_URL="https://staging-express.delhivery.com"
DELHIVERY_TOKEN=""
DELHIVERY_PICKUP_LOCATION="KYG-LAB-DELHI"
DELHIVERY_WEBHOOK_SECRET=""
DELHIVERY_MOCK="true"
